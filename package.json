{
  "type": "module",
  "name": "space-shooter",
  "version": "0.0.2",
  "description": "Incremental space shooter - defend your mothership!",
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "tsc": "tsc --noEmit",
    "finish": "npm run build && npm run lint:fix && npm run format"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.5",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-unused-imports": "^4.4.1",
    "prettier": "^3.8.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.12"
  },
  "volta": {
    "node": "24.14.0"
  }
}
